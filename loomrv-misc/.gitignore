# ── Temp directory (inline-generated wrappers, temp property files) ───────────
tmp/

prop_files/

# ── Generated traces (large, fully reproducible) ──────────────────────────────
generated_trace_*.jsonl
generated_trace_*.row.bin
*.ryl

