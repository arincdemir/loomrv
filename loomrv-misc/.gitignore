traces/

# ── Synthetic formula sets (generated by tools/generate_test_formulas.py) ─────
synthetic_*/

# ── Runtime-generated property files (written by scripts at benchmark time) ───
multi_properties.txt
multi_properties_and.txt

# ── Temp wrapper scripts written inline by benchmark_synthetic_dense.sh ─────────────
run_doverify_seq.sh
run_ryjson_seq_synthetic.sh
run_doverify_seq_synthetic.sh
temp_single_prop_*.txt

# ── Benchmark results (stored in results/<YYYY-MM-DD_HH-MM-SS>/ folders) ───────
